<% if (title) { %>
  <h1><%= title %></h1>
<% } else { %>
  <h1>Login</h1>
<% } %>

<%- messages() %>

<div class="login-container"> <form action="/account/login" method="post">
    
    <label for="emailAddr">Email Address:</label>
    <input type="email" name="account_email" id="emailAddr" required placeholder="Enter your email">

    <label for="accountPassword">Password:</label>
    <span class="password-hint">
      Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character
    </span>
    <input type="password" name="account_password" id="accountPassword" required 
           pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

    <button type="submit">Login</button>
  </form>
  
  <p class="signup-link">No account? <a href="/account/registration">Sign up</a></p>
</div>